<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= topic.title %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, sans-serif;
      background: #f5f7fa;
      padding: 2rem 1rem;
      max-width: 800px;
      margin: 0 auto;
    }
    h1 { font-size: 2rem; color: #0f172a; }
    .back { color: #3b82f6; text-decoration: none; }
    .back:hover { text-decoration: underline; }
    hr { margin: 1.2rem 0; border: none; border-top: 2px solid #e2e8f0; }
    .post {
      background: white;
      border-radius: 14px;
      padding: 1.2rem 1.5rem;
      margin-bottom: 1rem;
      border: 1px solid #e2e8f0;
      box-shadow: 0 2px 6px rgba(0,0,0,0.02);
    }
    .post-content {
      white-space: pre-wrap;
      word-wrap: break-word;
      line-height: 1.6;
    }
    .post-meta {
      margin-top: 0.5rem;
      font-size: 0.8rem;
      color: #64748b;
    }
    .post-media {
      margin-top: 0.8rem;
      max-width: 100%;
      border-radius: 10px;
      overflow: hidden;
    }
    .post-media img,
    .post-media video {
      max-width: 100%;
      max-height: 500px;
      border-radius: 10px;
      display: block;
      background: #f1f5f9;
    }
    .reply-form {
      background: white;
      padding: 1.2rem 1.5rem;
      border-radius: 14px;
      border: 1px solid #e2e8f0;
      margin-top: 1.5rem;
    }
    .reply-form h3 {
      margin-bottom: 0.75rem;
      color: #0f172a;
    }
    .reply-form textarea {
      width: 100%;
      padding: 0.6rem;
      border: 1px solid #cbd5e1;
      border-radius: 8px;
      font-size: 1rem;
      resize: vertical;
    }
    .reply-form input[type="file"] {
      margin: 0.5rem 0;
    }
    .reply-form button {
      background: #3b82f6;
      color: white;
      border: none;
      padding: 0.6rem 1.5rem;
      border-radius: 8px;
      font-weight: 500;
      cursor: pointer;
      margin-top: 0.5rem;
    }
    .reply-form button:hover { background: #2563eb; }
    .file-hint { font-size: 0.85rem; color: #475569; margin: 0.25rem 0 0.5rem; }
  </style>
</head>
<body>
  <h1><%= topic.title %></h1>
  <a class="back" href="/game/<%= topic.gameId %>">← Назад к игре</a>
  <hr>

  <% posts.forEach(post => { %>
    <div class="post">
      <div class="post-content"><%= post.content %></div>

      <% if (post.media) { %>
        <div class="post-media">
          <% if (post.media.match(/\.(jpg|jpeg|png|gif|webp|bmp|svg)$/i)) { %>
            <img src="<%= post.media %>" alt="Изображение" />
          <% } else if (post.media.match(/\.(mp4|webm|ogg|mov|avi|mkv)$/i)) { %>
            <video controls>
              <source src="<%= post.media %>" />
              Ваш браузер не поддерживает видео.
            </video>
          <% } else { %>
            <a href="<%= post.media %>">📎 Скачать файл</a>
          <% } %>
        </div>
      <% } %>

      <div class="post-meta">
        🕒 <%= post.createdAt.toLocaleString() %>
      </div>
    </div>
  <% }) %>

  <div class="reply-form">
    <h3>💬 Добавить сообщение</h3>
    <form method="POST" action="/topic/<%= topic.id %>" enctype="multipart/form-data">
      <textarea name="content" rows="3" required></textarea>
      <input type="file" name="media" accept="image/*,video/*" />
      <p class="file-hint">Прикрепите изображение или видео (необязательно)</p>
      <button type="submit">Отправить</button>
    </form>
  </div>
</body>
</html>