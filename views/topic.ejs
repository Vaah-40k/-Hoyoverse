<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title><%= topic.title %></title>
</head>
<body>
  <h1><%= topic.title %></h1>
  <a href="/game/<%= topic.gameId %>">← Назад к игре</a>
  <hr>
  <% posts.forEach(post => { %>
    <div style="border:1px solid #ccc; margin:10px; padding:5px;">
      <p><%= post.content %></p>
      <small><%= post.createdAt.toLocaleString() %></small>
    </div>
  <% }) %>

  <h3>Добавить сообщение</h3>
  <form method="POST" action="/topic/<%= topic.id %>">
    <textarea name="content" rows="3" cols="50" required></textarea><br>
    <button type="submit">Отправить</button>
  </form>
</body>
</html>