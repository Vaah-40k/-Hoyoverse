<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Новая тема в <%= game.name %></title>
  </head>
  <body>
    <h1>Новая тема в разделе: <%= game.name %></h1>
    <a href="/game/<%= game.id %>">← Назад</a>
    <hr />
    <form method="POST" action="/game/<%= game.id %>">
      <label>Заголовок темы:</label><br />
      <input
        type="text"
        name="title"
        required
        style="width: 300px"
      /><br /><br />
      <label>Первое сообщение:</label><br />
      <textarea name="content" rows="5" cols="50" required></textarea
      ><br /><br />
      <button type="submit">Создать тему</button>
    </form>
  </body>
</html>
